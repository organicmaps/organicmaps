<?xml version="1.0" encoding="utf-8"?>
<!-- Transit line bar rounded at the top only, for the very first ride leg (the start of the line).
     White so a runtime tint paints it with the line's own color. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
  android:shape="rectangle">
  <solid android:color="@android:color/white" />
  <corners
    android:topLeftRadius="@dimen/routing_transit_step_corner_radius"
    android:topRightRadius="@dimen/routing_transit_step_corner_radius" />
</shape>
