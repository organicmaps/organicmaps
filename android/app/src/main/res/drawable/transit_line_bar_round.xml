<?xml version="1.0" encoding="utf-8"?>
<!-- Transit line bar rounded at both ends, for a trip with a single ride leg (start and end of the
     line). White so a runtime tint paints it with the line's own color. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
  android:shape="rectangle">
  <solid android:color="@android:color/white" />
  <corners android:radius="@dimen/routing_transit_step_corner_radius" />
</shape>
