<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

  <!-- Values are persisted in the C++ core (not SharedPreferences), so persistent="false". -->
  <SwitchPreferenceCompat
      android:key="@string/pref_bg_tiles_enabled"
      android:title="@string/pref_bg_tiles_enable_title"
      android:persistent="false"
      app:singleLineTitle="false" />

  <!-- Inline text field (no popup dialog); the hint is set in code to the {z}/{x}/{y} example. -->
  <app.organicmaps.settings.InlineEditTextPreference
      android:key="@string/pref_bg_tiles_url"
      android:title="@string/pref_bg_tiles_url_title"
      android:persistent="false"
      app:singleLineTitle="false" />

  <SeekBarPreference
      android:key="@string/pref_bg_tiles_size"
      android:title="@string/pref_bg_tiles_size_title"
      android:persistent="false"
      app:singleLineTitle="false"
      app:showSeekBarValue="true" />

  <SeekBarPreference
      android:key="@string/pref_bg_tiles_opacity"
      android:title="@string/pref_bg_tiles_opacity_title"
      android:persistent="false"
      app:singleLineTitle="false"
      app:showSeekBarValue="true" />

  <Preference
      android:summary="@string/pref_bg_tiles_disclaimer"
      android:persistent="false"
      android:selectable="false"
      app:singleLineTitle="false" />

</androidx.preference.PreferenceScreen>
