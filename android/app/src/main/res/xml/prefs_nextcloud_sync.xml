<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools">

  <PreferenceCategory
    android:key="@string/pref_nc_auth_category"
    android:order="1"
    android:title="Authentication">

  <app.organicmaps.widget.BetterEditTextPreference
    android:key="@string/pref_nextcloud_server_url"
    android:order="1"
    android:selectAllOnFocus="true"
    android:title="Nextcloud Server URL" />

  <Preference
    android:key="@string/pref_nextcloud_connect"
    android:order="3"
    android:title="New Login" />

  <Preference
    android:key="@string/pref_nextcloud_progress"
    android:layout="@layout/horizontal_progressbar"
    android:order="4"
    android:selectable="false"
    android:visibility="gone"
    tools:visibility="visible" />

  <Preference
    android:key="@string/pref_nextcloud_logout"
    android:order="5"
    android:title="Log Out" />

  </PreferenceCategory>

  <PreferenceCategory
    android:key="@string/pref_category_nextcloud_sync_options"
    android:order="2"
    android:title="Sync Options">

  <app.organicmaps.sync.nc.SyncEnabledSwitchPreference
    android:defaultValue="false"
    android:key="@string/pref_nextcloud_sync_enabled"
    android:order="1"
    android:summary="Synchronize with Nextcloud"
    android:title="Enable Sync" />

  </PreferenceCategory>

</androidx.preference.PreferenceScreen>