<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/altitude_chart_panel"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="@dimen/margin_quarter_plus"
  android:layout_weight="1"
  android:orientation="vertical"
  android:paddingStart="@dimen/altitude_chart_container_padding_left"
  android:paddingEnd="@dimen/altitude_chart_container_padding_left"
  tools:showIn="@layout/fragment_routing">

  <LinearLayout
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
      android:orientation="vertical"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content">

      <TextView
        android:id="@+id/time_vehicle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        tools:text="5 h 55 min • 1555km"
        tools:visibility="visible"
        android:layout_marginTop="@dimen/margin_half"
        android:visibility="gone" />

      <LinearLayout
        android:id="@+id/time_elevation_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_half"
        android:layout_marginBottom="@dimen/margin_half"
        android:orientation="horizontal">

        <TextView
          android:id="@+id/time"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:ellipsize="end"
          android:maxLines="2"
          tools:text="5 h 55 min • 1555km"
          tools:visibility="visible" />

        <TextView
          android:id="@+id/altitude_difference"
          android:layout_width="wrap_content"
          android:layout_height="@dimen/altitude_chart_time_distance_height"
          android:fontFamily="@string/robotoMedium"
          android:gravity="center"
          android:textAppearance="@style/MwmTextAppearance.Body3"
          android:textColor="?colorAccent"
          android:visibility="gone"
          tools:text="↗ 43 m ↘ 88 m"
          tools:visibility="visible"
          android:layout_marginStart="@dimen/margin_half" />
      </LinearLayout>

      <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/transit_time"
        android:layout_marginTop="@dimen/margin_half"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
          android:id="@+id/total_time"
          style="@style/MwmWidget.TextView.PlanDetail.Number.Time"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent"
          tools:text="40 min" />

        <TextView
          android:id="@+id/dot"
          style="@style/MwmWidget.TextView.PlanDetail.Number.Secondary"
          android:text="•"
          app:layout_constraintTop_toTopOf="parent"
          tools:ignore="HardcodedText"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/margin_quarter_plus" />

        <ImageView
          android:id="@+id/pedestrian_icon"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          app:srcCompat="@drawable/ic_20px_route_planning_walk"
          app:tint="?iconTint"
          android:layout_marginStart="@dimen/margin_quarter_plus" />

        <TextView
          android:id="@+id/total_distance"
          style="@style/MwmWidget.TextView.PlanDetail.Number.Secondary"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          app:layout_constraintStart_toEndOf="@id/pedestrian_icon"
          app:layout_constraintTop_toTopOf="parent"
          tools:text="1 km"
          android:layout_marginStart="@dimen/margin_quarter_plus" />
      </LinearLayout>

      <TextView
        android:id="@+id/time_ruler"
        style="@style/MwmWidget.TextView.PlanDetail.Number.Time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="40 min"
        android:layout_marginTop="@dimen/margin_half"
        android:visibility="gone"
        tools:visibility="visible" />

    </LinearLayout>

    <FrameLayout
      android:id="@+id/driving_options_btn_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

      <ImageView
        android:id="@+id/driving_options_btn_img"
        android:layout_width="@dimen/margin_double"
        android:layout_height="@dimen/margin_double"
        android:layout_gravity="end"
        app:srcCompat="@drawable/ic_menu_settings"
        app:tint="?iconTint" />

      <!-- Layer 2: The Badge (on top of the icon) -->
      <TextView
        android:id="@+id/driving_options_badge"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_gravity="top|end"
        android:background="@drawable/badge_background"
        android:gravity="center"
        android:text="2"
        android:textColor="@android:color/white"
        android:textSize="8sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />
    </FrameLayout>
  </LinearLayout>

  <LinearLayout
    android:id="@+id/altitude_chart_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/altitude_chart"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:visibility="gone" />

  </LinearLayout>

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="12dp"
    android:scrollbarAlwaysDrawVerticalTrack="true"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintHeight_max="150dp"
    app:layout_constraintHorizontal_bias="0.0"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/total_time">

    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/transit_recycler_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:visibility="gone"
      tools:visibility="visible" />
  </ScrollView>

</LinearLayout>
