<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/place_page_notes_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <TextView
    android:id="@+id/tv__notes"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/margin_half"
    android:layout_marginEnd="@dimen/margin_base"
    android:layout_marginStart="@dimen/margin_base"
    android:layout_marginTop="@dimen/margin_base"
    android:textAppearance="?android:attr/textAppearance"
    android:visibility="gone"
    tools:text="Long, long text Long, long text Long, long text Long, long text Long, long text Long, long text "/>

  <ViewStub
    android:id="@+id/wv__notes_stub"
    android:layout="@layout/place_page_notes_webview"
    android:inflatedId="@+id/wv__notes"
    android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="@dimen/margin_half"
      android:layout_marginEnd="@dimen/margin_base"
      android:layout_marginStart="@dimen/margin_base"
      android:layout_marginTop="@dimen/margin_half" />

</LinearLayout>
