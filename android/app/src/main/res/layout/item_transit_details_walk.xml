<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="@dimen/margin_half"
  android:orientation="horizontal"
  android:gravity="center_vertical"
  android:paddingStart="@dimen/margin_base"
  android:paddingEnd="@dimen/margin_base">

  <!-- A walk is a travel leg like a transit ride, so its icon aligns with the line badges (inner
       column) rather than the stop headings. Matches the ride_summary_row start margin. -->
  <ImageView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/margin_base"
    app:srcCompat="@drawable/ic_20px_route_planning_walk"
    app:tint="?iconTint"/>

  <TextView
    android:id="@+id/walk_text"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/margin_half_plus"
    android:textAppearance="?fontBody1"
    android:textColor="?android:attr/textColorPrimary"
    tools:text="Walk · 3 min · 240 m"/>
</LinearLayout>
