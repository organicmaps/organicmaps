<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="@dimen/margin_half"
  android:orientation="horizontal"
  android:gravity="center_vertical"
  android:paddingStart="@dimen/margin_base"
  android:paddingEnd="@dimen/margin_base">

  <!-- The walk icon is centered in the shared legend column so it lines up on the same vertical axis
       as the ride legs' colored bars and the stop badges. -->
  <FrameLayout
    android:layout_width="@dimen/transit_details_legend_width"
    android:layout_height="wrap_content">

    <ImageView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      app:srcCompat="@drawable/ic_20px_route_planning_walk"
      app:tint="?iconTint"/>
  </FrameLayout>

  <TextView
    android:id="@+id/walk_text"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/margin_half"
    android:textAppearance="?fontBody1"
    android:textColor="?android:attr/textColorPrimary"
    tools:text="Walk · 3 min · 240 m"/>
</LinearLayout>
