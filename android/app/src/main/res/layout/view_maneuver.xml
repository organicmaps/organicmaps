<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/bg_nav_maneuver_card"
      android:orientation="vertical"
      android:padding="@dimen/margin_base">
    <app.organicmaps.sdk.widgets.lanes.LanesView
        android:id="@+id/maneuver_lanes"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="@dimen/margin_half"
        android:visibility="gone"
        app:lanesActiveLaneTintColor="@color/white_primary"
        app:lanesBackgroundColor="@android:color/transparent"
        app:lanesCornerRadius="0dp"
        app:lanesEditModeLanesCount="5"
        app:lanesInactiveLaneTintColor="@color/white_38"
        tools:visibility="visible" />
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

      <ImageView
          android:id="@+id/maneuver_turn"
          android:layout_width="@dimen/text_size_nav_number"
          android:layout_height="@dimen/text_size_nav_number"
          android:theme="?navigationTheme"
          app:tint="?iconTint"
          tools:src="@drawable/ic_turn_right"
          tools:visibility="gone"
          />

      <TextView
          android:id="@+id/maneuver_distance"
          style="@style/MwmWidget.TextView.NavNextTurn"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          tools:text="500 m" />
    </LinearLayout>
    <FrameLayout
        android:id="@+id/maneuver_street_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_quarter">

      <TextView
          android:id="@+id/maneuver_street"
          style="@style/MwmWidget.TextView.NavStreet"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:maxLines="2"
          android:textColor="@color/white_secondary"
          tools:text="Alexanderplatz Straße" />
    </FrameLayout>
  </LinearLayout>
</merge>
