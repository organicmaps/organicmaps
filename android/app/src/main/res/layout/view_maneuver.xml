<?xml version="1.0" encoding="utf-8"?>
<!-- Children of ManeuverView — a vertical LinearLayout that carries the rounded card
     background and content padding itself (see its constructor). -->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout"
    tools:background="@drawable/bg_nav_maneuver_card"
    tools:orientation="vertical"
    tools:padding="@dimen/margin_base">

  <app.organicmaps.sdk.widgets.lanes.LanesView
      android:id="@+id/maneuver_lanes"
      android:layout_width="match_parent"
      android:layout_height="60dp"
      android:layout_marginBottom="@dimen/margin_half"
      android:visibility="gone"
      app:lanesActiveLaneTintColor="@color/on_nav_card"
      app:lanesBackgroundColor="@android:color/transparent"
      app:lanesCornerRadius="0dp"
      app:lanesEditModeLanesCount="5"
      app:lanesInactiveLaneTintColor="@color/on_nav_card_inactive"
      tools:visibility="visible" />

  <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

    <ImageView
        android:id="@+id/maneuver_turn"
        android:layout_width="@dimen/nav_turn_sign_large"
        android:layout_height="@dimen/nav_turn_sign_large"
        android:layout_marginEnd="@dimen/margin_base"
        app:tint="@color/on_nav_card"
        tools:src="@drawable/ic_turn_right"
        tools:visibility="gone"
        />

    <TextView
        android:id="@+id/maneuver_distance"
        style="@style/MwmWidget.TextView.NavNextTurn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/on_nav_card"
        tools:text="500 m" />
  </LinearLayout>

  <FrameLayout
      android:id="@+id/maneuver_street_frame"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/margin_quarter">

    <TextView
        android:id="@+id/maneuver_street"
        style="@style/MwmWidget.TextView.NavStreet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:textColor="@color/on_nav_card_secondary"
        tools:text="Alexanderplatz Straße" />
  </FrameLayout>

  <!-- "Then" hint: the maneuver right after the upcoming one, shown when
       RoutingInfo.hasNextNextTurn() — the same predicate Android Auto's second step uses. -->
  <FrameLayout
      android:id="@+id/maneuver_next_next_turn_frame"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/margin_quarter"
      android:background="@drawable/bg_nav_next_next_turn"
      android:padding="@dimen/margin_quarter"
      android:visibility="gone"
      tools:visibility="visible">

    <ImageView
        android:id="@+id/maneuver_next_next_turn"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:tint="@color/on_nav_card"
        tools:src="@drawable/ic_turn_right" />
  </FrameLayout>
</merge>
