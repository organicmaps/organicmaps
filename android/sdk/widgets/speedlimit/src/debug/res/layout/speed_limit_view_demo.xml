<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

  <app.organicmaps.sdk.widgets.speedlimit.SpeedLimitView
      android:layout_width="60dp"
      android:layout_height="60dp"
      app:om_speed_limit_view_value="90" />

  <Space
      android:layout_width="wrap_content"
      android:layout_height="4dp" />

  <app.organicmaps.sdk.widgets.speedlimit.SpeedLimitView
      android:layout_width="60dp"
      android:layout_height="60dp"
      app:om_speed_limit_view_value="90"
      app:om_speed_limit_view_mode="warning" />

  <Space
      android:layout_width="wrap_content"
      android:layout_height="4dp" />

  <app.organicmaps.sdk.widgets.speedlimit.SpeedLimitView
      android:layout_width="60dp"
      android:layout_height="60dp"
      app:om_speed_limit_view_value="90"
      app:om_speed_limit_view_mode="alert" />

  <Space
      android:layout_width="wrap_content"
      android:layout_height="4dp" />

  <app.organicmaps.sdk.widgets.speedlimit.SpeedLimitView
      android:layout_width="60dp"
      android:layout_height="60dp"
      style="@style/OMSpeedLimitView.Mutcd"
      app:om_speed_limit_view_value="120"
      app:om_speed_limit_view_mode="normal" />

  <Space
      android:layout_width="wrap_content"
      android:layout_height="4dp" />

  <app.organicmaps.sdk.widgets.speedlimit.SpeedLimitView
      android:layout_width="60dp"
      android:layout_height="60dp"
      style="@style/OMSpeedLimitView.Mutcd"
      app:om_speed_limit_view_value="120"
      app:om_speed_limit_view_mode="warning"/>

  <Space
      android:layout_width="wrap_content"
      android:layout_height="4dp" />

  <app.organicmaps.sdk.widgets.speedlimit.SpeedLimitView
      android:layout_width="60dp"
      android:layout_height="60dp"
      style="@style/OMSpeedLimitView.Mutcd"
      app:om_speed_limit_view_value="120"
      app:om_speed_limit_view_mode="alert" />
</LinearLayout>
