#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: runs clang-format and swiftformat on staged source files.
# Automatically reformats and re-stages non-conforming files.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"

source "$REPO_ROOT/tools/hooks/format-config.bash"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=AM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

REFORMATTED=0

# --- clang-format -----------------------------------------------------------
CLANG_REGEX=$(build_path_regex CLANG_FORMAT_TARGETS)
CLANG_FILES=$(echo "$STAGED_FILES" | grep -E "$CLANG_REGEX" || true)

if [ -n "$CLANG_FILES" ]; then
  CLANG_FORMAT=$(resolve_clang_format)
  echo "pre-commit: using $($CLANG_FORMAT --version)"

  while IFS= read -r FILE; do
    [ -f "$FILE" ] || continue
    if ! "$CLANG_FORMAT" --dry-run --Werror "$FILE" > /dev/null 2>&1; then
      echo "clang-format: reformatting $FILE"
      "$CLANG_FORMAT" -i "$FILE"
      git add "$FILE"
      REFORMATTED=1
    fi
  done <<< "$CLANG_FILES"
fi

# --- swiftformat -------------------------------------------------------------
SWIFT_DIRS=$(printf '%s|' "${SWIFTFORMAT_TARGETS[@]}" | sed 's/|$//')
SWIFT_REGEX="^($SWIFT_DIRS)/.*\.swift$"
SWIFT_FILES=$(echo "$STAGED_FILES" | grep -E "$SWIFT_REGEX" || true)

if [ -n "$SWIFT_FILES" ]; then
  if ! command -v swiftformat >/dev/null 2>&1; then
    echo "Warning: swiftformat not found, skipping Swift files."
  else
    echo "pre-commit: using swiftformat $(swiftformat --version)"

    while IFS= read -r FILE; do
      [ -f "$FILE" ] || continue
      if ! swiftformat --lint "$FILE" > /dev/null 2>&1; then
        echo "swiftformat: reformatting $FILE"
        swiftformat "$FILE"
        git add "$FILE"
        REFORMATTED=1
      fi
    done <<< "$SWIFT_FILES"
  fi
fi

# --- ktlint ------------------------------------------------------------------
KTLINT_REGEX=$(build_path_regex KTLINT_TARGETS)
KTLINT_FILES=$(echo "$STAGED_FILES" | grep -E "$KTLINT_REGEX" || true)

if [ -n "$KTLINT_FILES" ]; then
  if KTLINT=$(resolve_ktlint); then
    echo "pre-commit: using ktlint $($KTLINT --version)"

    # Collect existing files for a single JVM invocation (~2s total instead of ~2s per file).
    KTLINT_ARGS=()
    while IFS= read -r FILE; do
      [ -f "$FILE" ] && KTLINT_ARGS+=("$FILE")
    done <<< "$KTLINT_FILES"

    if [ ${#KTLINT_ARGS[@]} -gt 0 ]; then
      # ktlint has no --dry-run; hash files before/after to skip re-staging
      # when ktlint made no changes (avoids spurious "reformatted" lines and
      # avoids re-staging unrelated worktree state when nothing was changed).
      KTLINT_HASHES=()
      for i in "${!KTLINT_ARGS[@]}"; do
        KTLINT_HASHES[$i]=$(git hash-object "${KTLINT_ARGS[$i]}")
      done

      set +e
      "$KTLINT" --editorconfig="$REPO_ROOT/android/.editorconfig" --format "${KTLINT_ARGS[@]}"
      kt_rc=$?
      set -e

      for i in "${!KTLINT_ARGS[@]}"; do
        AFTER=$(git hash-object "${KTLINT_ARGS[$i]}")
        if [ "${KTLINT_HASHES[$i]}" != "$AFTER" ]; then
          echo "ktlint: reformatted ${KTLINT_ARGS[$i]}"
          git add "${KTLINT_ARGS[$i]}"
          REFORMATTED=1
        fi
      done

      if [ $kt_rc -ne 0 ]; then
        echo "ktlint: unfixable violations above — fix manually and re-commit."
        exit 1
      fi
    fi
  else
    echo "Warning: ktlint not found, skipping Kotlin files."
  fi
fi

# -----------------------------------------------------------------------------
# Fail if reformatting eliminated all staged changes (would create an empty commit).
if [ "$REFORMATTED" -eq 1 ]; then
  if git diff --cached --quiet; then
    echo "pre-commit: nothing to commit after reformatting — all staged changes were formatting-only."
    exit 1
  fi
  echo "pre-commit: some files were reformatted and re-staged."
fi

exit 0
